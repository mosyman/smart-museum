<view class="tab-bar">
  <view class="tab-item {{current === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
    <view class="tab-emoji">🏠</view>
    <view class="tab-text">首页</view>
  </view>
  <view class="tab-item {{current === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
    <view class="tab-emoji">🗺️</view>
    <view class="tab-text">导览</view>
  </view>
  <view class="tab-item {{current === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
    <view class="tab-emoji">👣</view>
    <view class="tab-text">足迹</view>
  </view>
  <view class="tab-item {{current === 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3">
    <view class="tab-emoji">👤</view>
    <view class="tab-text">我的</view>
  </view>
</view>

<view class="tab-bar-placeholder"></view>