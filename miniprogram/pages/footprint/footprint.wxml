<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 参观报告卡片 -->
    <view class="report-card" wx:if="{{visitRecords.length > 0}}">
      <view class="report-title">📊 参观报告</view>
      <view class="report-stats">
        <view class="stat-item">
          <text class="stat-value">{{report.totalCount}}</text>
          <text class="stat-label">参观展品</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{report.totalDuration}}</text>
          <text class="stat-label">总时长(秒)</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{report.favoriteCategory}}</text>
          <text class="stat-label">偏好分类</text>
        </view>
      </view>
    </view>

    <!-- 足迹列表 -->
    <view class="footprint-list" wx:if="{{visitRecords.length > 0}}">
      <view class="list-header">
        <text class="header-title">📝 参观记录</text>
        <text class="header-clear" bindtap="clearFootprint">清空</text>
      </view>
      
      <!-- 关键：data-id="{{item.exhibitId}}" -->
      <view class="footprint-item" wx:for="{{visitRecords}}" wx:key="recordId" bindtap="goToExhibit" data-id="{{item.exhibitId}}">
        <image class="footprint-image" src="{{item.imageUrl || defaultImg}}" mode="aspectFill" />
        <view class="footprint-info">
          <text class="footprint-name">{{item.exhibitName}}</text>
          <text class="footprint-time">📅 {{item.visitTime}}</text>
          <text class="footprint-duration">⏱️ 停留 {{item.duration}} 秒</text>
        </view>
        <view class="footprint-arrow">
          <text>›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <text class="empty-emoji">👣</text>
      <text class="empty-text">暂无参观记录</text>
      <text class="empty-tip">去首页逛逛展品，留下你的足迹吧～</text>
    </view>

    <!-- 为你推荐 -->
    <view class="report-card" wx:if="{{recommends.length > 0}}">
      <view class="report-title">✨ 为你推荐</view>
      <scroll-view scroll-x class="hot-list" style="white-space:nowrap;">
        <view class="hot-item" wx:for="{{recommends}}" wx:key="id" bindtap="goToExhibit" data-id="{{item.id}}" style="display:inline-block;margin-right:20rpx;width:200rpx;">
          <image src="{{item.imageUrl || defaultImg}}" mode="aspectFill" style="width:200rpx;height:200rpx;border-radius:12rpx;" />
          <text style="display:block;font-size:24rpx;margin-top:8rpx;">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </block>
</view>

<tab-bar current="2"></tab-bar>