.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

/* 报告卡片 */
.report-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.report-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.report-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

/* 足迹列表 */
.footprint-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.header-clear {
  font-size: 24rpx;
  color: #f56c6c;
}

.footprint-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.footprint-item:active {
  background-color: #f9f9f9;
}

.footprint-item:last-child {
  border-bottom: none;
}

.footprint-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.footprint-info {
  flex: 1;
}

.footprint-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.footprint-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.footprint-duration {
  display: block;
  font-size: 22rpx;
  color: #3b5998;
}

.footprint-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-top: 100rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.menu-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}