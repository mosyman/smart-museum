.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-emoji {
  font-size: 50rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-username {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.logout-btn {
  background-color: rgba(255,255,255,0.2);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 24rpx;
}

/* 统计卡片 */
.stats-card {
  background-color: #fff;
  border-radius: 16rpx;
  display: flex;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  background-color: #eee;
}

/* 功能菜单 */
.menu-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 未登录提示 */
.login-prompt {
  text-align: center;
  padding: 100rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-top: 100rpx;
}

.prompt-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.prompt-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.prompt-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.login-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  width: 60%;
  margin: 0 auto 20rpx;
}

.register-link {
  background: none;
  color: #667eea;
  font-size: 26rpx;
  width: auto;
}

/* 弹窗 */
.login-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-bar {
  display: flex;
  gap: 40rpx;
}

.tab-item {
  font-size: 32rpx;
  color: #999;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
  border-bottom: 2rpx solid #667eea;
  padding-bottom: 8rpx;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
}

.modal-body {
  padding: 40rpx;
}

.login-input {
  border: 1rpx solid #eee;
  border-radius: 44rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  margin-top: 20rpx;
}