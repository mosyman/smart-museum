.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.exhibit-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  background-color: #f0f0f0;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.exhibit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.exhibit-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.exhibit-actions {
  display: flex;
  gap: 20rpx;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
}

.exhibit-category {
  display: inline-block;
  background-color: #f0f0f0;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.exhibit-description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
  display: block;
}

.location-info {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
  font-size: 26rpx;
  color: #999;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.view-count {
  color: #3b5998;
}

.btn-3d {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

/* 404 友好提示 */
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  text-align: center;
}
.nf-emoji { font-size: 100rpx; margin-bottom: 30rpx; }
.nf-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.nf-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 40rpx;
}
.nf-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
  padding: 18rpx 60rpx;
  border: none;
}