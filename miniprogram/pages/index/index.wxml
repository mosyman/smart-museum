<!-- 首页 -->
<view class="container">
  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots autoplay circular>
    <swiper-item wx:for="{{banners}}" wx:key="index">
      <image class="banner-image" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="quick-menu">
  <view class="menu-item" bindtap="goToMap">
    <text class="menu-emoji">🗺️</text>
    <text class="menu-text">地图导览</text>
  </view>
  <view class="menu-item" bindtap="scanQRCode">
    <text class="menu-emoji">📷</text>
    <text class="menu-text">扫码讲解</text>
  </view>
  <view class="menu-item" bindtap="goToFootprint">
    <text class="menu-emoji">👣</text>
    <text class="menu-text">我的足迹</text>
  </view>
  <view class="menu-item" bindtap="goToCollection">
    <text class="menu-emoji">🏛️</text>
    <text class="menu-text">馆藏集珍</text>
  </view>
  <view class="menu-item" bindtap="recommendRouteByTime">
    <text class="menu-emoji">🧭</text>
    <text class="menu-text">智能推荐</text>
  </view>
</view>

  <!-- 热门展品 -->
  <view class="card">
    <view class="card-title">热门展品</view>
    <scroll-view scroll-x class="hot-list">
      <view class="hot-item" wx:for="{{hotExhibits}}" wx:key="id" bindtap="goToExhibit" data-id="{{item.id}}">
        <image class="hot-image" src="{{item.imageUrl || '/images/default.jpg'}}" mode="aspectFill" />
        <text class="hot-name">{{item.name}}</text>
        <text class="hot-count">❤️ {{item.viewCount}}</text>
      </view>
    </scroll-view>
  </view>

<!-- 推荐路线 -->
<view class="card">
  <view class="card-title">推荐路线</view>
  <view class="route-item" wx:for="{{routes}}" wx:key="id" bindtap="goToRoute" data-id="{{item.id}}">
    <view class="route-info">
      <text class="route-name">{{item.name}}</text>
      <text class="route-desc">{{item.description}}</text>
      <text class="route-time">⏱️ {{item.recommendTime}}分钟</text>
    </view>
    <text class="route-arrow">›</text>
  </view>
</view>
</view>

<!-- 路线详情弹窗 -->
<view class="route-mask" wx:if="{{showRouteModal}}" bindtap="closeRouteModal">
  <view class="route-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{currentRoute.name}}</text>
      <text class="modal-close" bindtap="closeRouteModal">✕</text>
    </view>
    <view class="modal-body">
      <view class="route-detail-item">
        <text class="label">路线描述：</text>
        <text class="value">{{currentRoute.description}}</text>
      </view>
      <view class="route-detail-item">
        <text class="label">推荐时长：</text>
        <text class="value">{{currentRoute.recommendTime}} 分钟</text>
      </view>
      <view class="route-detail-item">
        <text class="label">途经楼层：</text>
        <text class="value">{{currentRoute.floor}} 楼</text>
      </view>
      <view class="route-detail-item">
        <text class="label">途经展品：</text>
        <view class="waypoint-list">
          <view class="waypoint-item" wx:for="{{routeExhibits}}" wx:key="id" bindtap="goToExhibit" data-id="{{item.id}}">
            <image class="waypoint-img" src="{{item.imageUrl || defaultImg}}" mode="aspectFill" />
            <text class="waypoint-name">{{item.name}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="nav-btn" bindtap="startNavigation">开始导航</button>
    </view>
  </view>
</view>

<tab-bar current="0"></tab-bar>