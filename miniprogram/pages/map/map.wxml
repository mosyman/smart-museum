<view class="container">

  <!-- 楼层切换 -->
  <view class="floor-tabs">
    <view
      class="floor-tab {{currentFloor === item ? 'active' : ''}}"
      wx:for="{{floors}}" wx:key="*this"
      bindtap="switchFloor" data-floor="{{item}}"
    >{{item}}F</view>
  </view>

  <!-- 路线选择 -->
  <view class="route-bar">
    <picker bindchange="onRouteChange" range="{{routes}}" range-key="name">
      <view class="picker {{showRoute ? 'active' : ''}}">
        <text class="icon">🧭</text>
        <text class="picker-text">{{selectedRoute ? selectedRoute.name : '选择推荐路线'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    <view class="clear-btn" wx:if="{{showRoute}}" bindtap="clearRoute">清除</view>
  </view>

  <!-- 路线信息卡 -->
  <view class="route-card" wx:if="{{showRoute && selectedRoute}}">
    <view class="rc-info">
      <view class="rc-name">{{selectedRoute.name}}</view>
      <view class="rc-meta">⏱ {{selectedRoute.recommendTime}} 分钟 · {{waypointIds.length}} 站 · 本层 {{onFloorCount}} 站</view>
    </view>
    <view class="rc-btn" bindtap="startNavigation">开始导航 →</view>
  </view>

  <!-- 平面图区域 -->
  <view class="floor-plan">
    <image class="fp-image" src="{{floorPlanUrl}}" mode="widthFix" />

    <!-- 展品标记（绝对定位，叠在平面图上） -->
    <view
      class="marker {{item.routeIdx > 0 ? 'marker-route' : (item.visited ? 'marker-visited' : 'marker-normal')}}"
      wx:for="{{floorExhibits}}" wx:key="id"
      style="left: {{item.pctX}}%; top: {{item.pctY}}%;"
      bindtap="goToExhibit" data-id="{{item.id}}"
    >
      <view class="marker-dot">
        <text wx:if="{{item.routeIdx > 0}}">{{item.routeIdx}}</text>
        <text wx:elif="{{item.visited}}">✓</text>
        <text wx:else>•</text>
      </view>
      <text class="marker-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 图例 -->
  <view class="legend">
    <view class="lg-item"><view class="lg-dot lg-normal"></view>未参观</view>
    <view class="lg-item"><view class="lg-dot lg-route"></view>路线途经</view>
    <view class="lg-item"><view class="lg-dot lg-visited"></view>已参观</view>
  </view>

  <!-- 底部展品列表 -->
  <view class="bottom-list">
    <view class="bl-title">📋 {{currentFloor}}F 展品（共 {{floorExhibits.length}} 件）</view>
    <scroll-view scroll-x class="bl-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="bl-card {{item.routeIdx > 0 ? 'bl-card-route' : ''}} {{item.visited ? 'bl-card-visited' : ''}}"
        wx:for="{{floorExhibits}}" wx:key="id"
        bindtap="goToExhibit" data-id="{{item.id}}"
      >
        <image class="bl-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="bl-badge" wx:if="{{item.routeIdx > 0}}">{{item.routeIdx}}</view>
        <view class="bl-badge bl-badge-v" wx:elif="{{item.visited}}">✓</view>
        <text class="bl-name">{{item.name}}</text>
        <text class="bl-sub">{{item.locationArea}} · {{item.category}}</text>
      </view>
    </scroll-view>
  </view>
</view>

<tab-bar current="1"></tab-bar>
