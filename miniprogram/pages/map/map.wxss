.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 楼层切换 */
.floor-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 44rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}
.floor-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  transition: all 0.25s;
}
.floor-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 路线选择 */
.route-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.picker {
  flex: 1;
  background-color: #fff;
  padding: 22rpx 28rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.picker.active {
  background-color: #fff7eb;
  color: #c97a3b;
}
.icon { font-size: 28rpx; }
.picker-text { flex: 1; }
.arrow { font-size: 22rpx; color: #999; }
.clear-btn {
  background-color: #fef0f0;
  padding: 18rpx 28rpx;
  border-radius: 44rpx;
  font-size: 24rpx;
  color: #f56c6c;
}

/* 路线卡 */
.route-card {
  background: linear-gradient(135deg, #fff8e1 0%, #fff3d0 100%);
  border: 1rpx solid #f5c97a;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.rc-info { flex: 1; }
.rc-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #c97a3b;
  margin-bottom: 6rpx;
}
.rc-meta {
  font-size: 22rpx;
  color: #8a6c3f;
}
.rc-btn {
  background: linear-gradient(135deg, #f5a623 0%, #e6a23c 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  padding: 18rpx 28rpx;
  border-radius: 40rpx;
  white-space: nowrap;
}

/* 平面图 */
.floor-plan {
  position: relative;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.fp-image {
  width: 100%;
  display: block;
  /* viewBox 400×300 → aspect-ratio 4:3，widthFix 自动算高 */
}

/* 展品标记 */
.marker {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}
.marker-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.25);
  border: 2rpx solid #fff;
}
.marker-name {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #333;
  background-color: rgba(255,255,255,0.85);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.marker-normal .marker-dot { background-color: #3b5998; }
.marker-route  .marker-dot { background-color: #e6a23c; width: 40rpx; height: 40rpx; font-size: 22rpx; }
.marker-route  .marker-name { color: #c97a3b; font-weight: bold; }
.marker-visited .marker-dot { background-color: #888; }
.marker-visited .marker-name { color: #888; text-decoration: line-through; }

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: #666;
}
.lg-item { display: flex; align-items: center; gap: 8rpx; }
.lg-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 1.5rpx solid #fff;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.2);
}
.lg-normal { background-color: #3b5998; }
.lg-route  { background-color: #e6a23c; }
.lg-visited { background-color: #888; }

/* 底部展品列表 */
.bottom-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}
.bl-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.bl-scroll {
  white-space: nowrap;
}
.bl-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
  position: relative;
  vertical-align: top;
}
.bl-card:active { opacity: 0.7; }
.bl-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}
.bl-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bl-sub {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.bl-card-route .bl-name { color: #c97a3b; font-weight: bold; }
.bl-card-visited .bl-img { opacity: 0.55; }
.bl-card-visited .bl-name { text-decoration: line-through; color: #999; }
.bl-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background-color: #e6a23c;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}
.bl-badge-v { background-color: #888; }
