.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 楼层切换 */
.floor-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
}

.floor-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.floor-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 路线选择 */
.route-selector {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.picker {
  flex: 1;
  background-color: #fff;
  padding: 24rpx 30rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}

.clear-route {
  background-color: #fef0f0;
  padding: 20rpx 30rpx;
  border-radius: 44rpx;
  font-size: 26rpx;
  color: #f56c6c;
}

/* 地图区域 */
.map-area {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow-x: auto;
}

.map-grid {
  min-width: 1000rpx;
}

.map-row {
  display: flex;
}

.map-cell {
  width: 200rpx;
  height: 200rpx;
  border: 1rpx solid #eee;
  position: relative;
  background-color: #fafafa;
}

/* 展品标记 */
.exhibit-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(59, 89, 152, 0.9);
  border-radius: 60rpx;
  padding: 10rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.exhibit-marker.route-marker {
  background-color: #e6a23c;
}

.marker-icon {
  font-size: 28rpx;
}

.marker-name {
  font-size: 22rpx;
  color: #fff;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 展品列表 */
.exhibit-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.list-scroll {
  white-space: nowrap;
}

.exhibit-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  text-align: center;
}

.card-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background-color: #f0f0f0;
}

.card-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-category {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 导航按钮 */
.nav-btn {
  background: linear-gradient(135deg, #67c23a 0%, #5caf32 100%);
  border-radius: 44rpx;
  padding: 28rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.nav-btn text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 路线信息 */
.route-info {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  color: #fff;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.info-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.info-time {
  font-size: 24rpx;
  opacity: 0.8;
}