<view class="container">
  <view class="exhibit-grid" wx:if="{{exhibits.length > 0}}">
    <view class="exhibit-card" wx:for="{{exhibits}}" wx:key="id">
      <!-- 可点击的卡片内容 -->
      <view class="card-clickable" bindtap="goToExhibit" data-id="{{item.id}}">
        <image class="card-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-category">{{item.category}}</text>
        </view>
      </view>
      <!-- 收藏按钮 -->
      <view class="card-favorite">
        <view class="favorite-btn {{item.isFavorited ? 'active' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
          <text>{{item.isFavorited ? '❤️' : '🤍'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && exhibits.length === 0}}">
    <text>暂无展品</text>
  </view>
</view>

<!-- 底部导航栏放在最后 -->
