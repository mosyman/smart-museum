.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 展品网格 */
.exhibit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.exhibit-card {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s;
}

.exhibit-card:active {
  transform: scale(0.98);
}

.card-image {
  width: 100%;
  height: 300rpx;
  background-color: #f0f0f0;
}

.card-info {
  padding: 20rpx;
}

.card-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-category {
  display: inline-block;
  background-color: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.card-actions {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.favorite-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.favorite-btn.active {
  background-color: rgba(245, 108, 108, 0.8);
}

.loading-state, .load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

.load-more {
  background-color: #fff;
  border-radius: 44rpx;
  margin: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}